<Window x:Class="TunesLayer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TunesLayer.App.ViewModels"
        mc:Ignorable="d"
        Title="TunesLayer - Settings"
        Height="650" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanMinimize">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <!-- TabControl style with fixed 2-row grid layout -->
        <Style TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Use UniformGrid with 2 rows to prevent row swapping -->
                            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="10,5">
                                <UniformGrid x:Name="HeaderPanel" Rows="2" IsItemsHost="True"/>
                            </Border>
                            <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderThickness="0">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- TabItem style -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}" Margin="2"
                                Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header with gradient background -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="30,25">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock Text="TunesLayer" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}" />
                        <TextBlock Text="Music Overlay" FontSize="13" 
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Tab Control for Settings -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,0">
            
            <!-- General Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="General" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <!-- Startup Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Startup Behavior" FontWeight="SemiBold" FontSize="15" 
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                                <TextBlock Text="Configure how TunesLayer behaves when Windows starts" 
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,15" TextWrapping="Wrap" />
                                
                                <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}"
                                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                                <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"
                                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                                <CheckBox Content="Show overlay on startup" IsChecked="{Binding ShowOverlayOnStartup}"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Overlay Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Overlay" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <!-- Appearance Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                                <TextBlock Text="Adjust the visual appearance of the overlay"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,20" TextWrapping="Wrap" />
                                
                                <TextBlock Text="Opacity" Foreground="{DynamicResource ForegroundBrush}" FontWeight="Medium" />
                                <TextBlock Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}" 
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3,0,8" />
                                <Slider Minimum="0.3" Maximum="1.0" Value="{Binding OverlayOpacity}"
                                        Margin="0,0,0,20" />
                                
                                <TextBlock Text="Size" Foreground="{DynamicResource ForegroundBrush}" FontWeight="Medium" />
                                <TextBlock Text="{Binding OverlaySize, StringFormat={}{0:0}px}" 
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3,0,8" />
                                <Slider Minimum="150" Maximum="400" Value="{Binding OverlaySize}" />
                            </StackPanel>
                        </Border>
                        
                        <!-- Behavior Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                                <TextBlock Text="Configure how the overlay interacts with other windows"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,15" TextWrapping="Wrap" />
                                
                                <CheckBox Content="Enable click-through mode" IsChecked="{Binding ClickThroughEnabled}"
                                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                                <CheckBox Content="Show track change notifications" IsChecked="{Binding ShowNotifications}"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Hotkeys Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Hotkeys" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Global Hotkeys" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                                <TextBlock Text="Control playback and overlay from anywhere using keyboard shortcuts"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,20" TextWrapping="Wrap" />
                                
                                <!-- Media Controls -->
                                <TextBlock Text="Media Controls" FontWeight="Medium" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Play / Pause" Foreground="{DynamicResource ForegroundBrush}" 
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" 
                                            CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="{Binding HotkeyPlayPause}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextAlignment="Center" FontFamily="Consolas" />
                                    </Border>
                                </Grid>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Next Track" Foreground="{DynamicResource ForegroundBrush}" 
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" 
                                            CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="{Binding HotkeyNext}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextAlignment="Center" FontFamily="Consolas" />
                                    </Border>
                                </Grid>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Previous Track" Foreground="{DynamicResource ForegroundBrush}" 
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" 
                                            CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="{Binding HotkeyPrevious}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextAlignment="Center" FontFamily="Consolas" />
                                    </Border>
                                </Grid>
                                
                                <!-- Overlay Controls -->
                                <TextBlock Text="Overlay Controls" FontWeight="Medium" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toggle Overlay" Foreground="{DynamicResource ForegroundBrush}" 
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" 
                                            CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="{Binding HotkeyToggleOverlay}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextAlignment="Center" FontFamily="Consolas" />
                                    </Border>
                                </Grid>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toggle Click-Through" Foreground="{DynamicResource ForegroundBrush}" 
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" 
                                            CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="{Binding HotkeyToggleClickThrough}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextAlignment="Center" FontFamily="Consolas" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Themes Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Themes" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                    <StackPanel Margin="30,20">
                        <TextBlock Text="Choose Theme" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                        <TextBlock Text="Select a visual theme for TunesLayer"
                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                   Margin="0,0,0,15" TextWrapping="Wrap" />
                        
                        <ItemsControl ItemsSource="{Binding AvailableThemes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" Margin="0,0,0,8" CornerRadius="8"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="ThemeItem_Click"
                                            Tag="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{DynamicResource ForegroundBrush}" />
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                       Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Integrations Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Integrations" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <!-- Discord Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,10,0" />
                                    <TextBlock Text="Discord" FontWeight="SemiBold" FontSize="15"
                                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Show what you're listening to in your Discord status"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,15" TextWrapping="Wrap" />
                                
                                <CheckBox Content="Enable Discord Rich Presence" IsChecked="{Binding DiscordEnabled}"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </StackPanel>
                        </Border>
                        
                        <!-- OBS Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,10,0" />
                                    <TextBlock Text="OBS / Streaming" FontWeight="SemiBold" FontSize="15"
                                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Display now playing in your streams and recordings"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                           Margin="0,0,0,15" TextWrapping="Wrap" />
                                
                                <CheckBox Content="Enable Now Playing Widget Server" IsChecked="{Binding OBSWidgetEnabled}"
                                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12" />
                                
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="Widget URL" FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <TextBlock Text="http://localhost:5123/widget"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FontFamily="Consolas" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Analytics Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Analytics" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <TextBlock Text="Listening Statistics" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5" />
                        <TextBlock Text="Track your music listening habits"
                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                                   Margin="0,0,0,15" TextWrapping="Wrap" />
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                 <TextBlock Text="&#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Today's Listening Time" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding TodayListeningTime}" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}" />
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Tracks Played Today" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding TracksPlayedToday}" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}" />
                            </StackPanel>
                        </Border>
                        
                        <Button Content="View Full Analytics" Command="{Binding OpenAnalyticsCommand}"
                                Padding="0" Height="44" Background="{DynamicResource PrimaryBrush}"
                                Foreground="White" BorderThickness="0" FontWeight="Medium" Cursor="Hand" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" Padding="25,18" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="v1.0.0" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" 
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Show Overlay" Command="{Binding ShowOverlayCommand}"
                            Padding="20,10" Margin="0,0,10,0" Background="{DynamicResource PrimaryBrush}"
                            Foreground="White" BorderThickness="0" FontWeight="Medium" Cursor="Hand" />
                    <Button Content="Hide to Tray" Command="{Binding HideToTrayCommand}"
                            Padding="20,10" Background="{DynamicResource BackgroundBrush}"
                            Foreground="{DynamicResource ForegroundBrush}" BorderThickness="1" 
                            BorderBrush="{DynamicResource BorderBrush}" FontWeight="Medium" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
