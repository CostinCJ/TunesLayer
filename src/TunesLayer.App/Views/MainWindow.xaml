<Window x:Class="TunesLayer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TunesLayer.App.ViewModels"
        mc:Ignorable="d"
        Title="TunesLayer - Settings"
        Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanMinimize">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="TunesLayer" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="Gaming Music Overlay" 
                       FontSize="14" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,5,0,0" />
        </StackPanel>
        
        <!-- Tab Control for Settings -->
        <TabControl Grid.Row="1" 
                    Background="Transparent"
                    BorderThickness="0">
            
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Startup" FontWeight="SemiBold" FontSize="14" 
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        <CheckBox Content="Start with Windows" 
                                  IsChecked="{Binding StartWithWindows}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        <CheckBox Content="Start minimized to tray" 
                                  IsChecked="{Binding StartMinimized}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  Margin="0,8,0,0" />
                        <CheckBox Content="Show overlay on startup" 
                                  IsChecked="{Binding ShowOverlayOnStartup}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Overlay Tab -->
            <TabItem Header="Overlay">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        
                        <TextBlock Text="Opacity" Foreground="{DynamicResource ForegroundBrush}" />
                        <Slider Minimum="0.3" Maximum="1.0" 
                                Value="{Binding OverlayOpacity}"
                                Margin="0,5,0,15" />
                        
                        <TextBlock Text="Size" Foreground="{DynamicResource ForegroundBrush}" />
                        <Slider Minimum="150" Maximum="400" 
                                Value="{Binding OverlaySize}"
                                Margin="0,5,0,15" />
                        
                        <CheckBox Content="Enable click-through mode" 
                                  IsChecked="{Binding ClickThroughEnabled}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        
                        <CheckBox Content="Show track notifications" 
                                  IsChecked="{Binding ShowNotifications}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Hotkeys Tab -->
            <TabItem Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Global Hotkeys" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Play/Pause" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding HotkeyPlayPause}" IsReadOnly="True" />
                        </Grid>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Next Track" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding HotkeyNext}" IsReadOnly="True" />
                        </Grid>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Previous Track" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding HotkeyPrevious}" IsReadOnly="True" />
                        </Grid>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toggle Overlay" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding HotkeyToggleOverlay}" IsReadOnly="True" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Themes Tab -->
            <TabItem Header="Themes">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Select Theme" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        
                        <ListBox ItemsSource="{Binding AvailableThemes}"
                                 SelectedItem="{Binding SelectedTheme}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,2" CornerRadius="5"
                                            Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}" />
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Integrations Tab -->
            <TabItem Header="Integrations">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Discord" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        <CheckBox Content="Enable Discord Rich Presence" 
                                  IsChecked="{Binding DiscordEnabled}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        
                        <TextBlock Text="OBS / Streaming" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,20,0,10" />
                        <CheckBox Content="Enable Now Playing Widget Server" 
                                  IsChecked="{Binding OBSWidgetEnabled}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        <TextBlock Text="Widget URL: http://localhost:5123/widget"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="20,5,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Analytics Tab -->
            <TabItem Header="Analytics">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Listening Statistics" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10" />
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" 
                                CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Today's Listening Time" 
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding TodayListeningTime}" 
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" 
                                CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Tracks Played Today" 
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding TracksPlayedToday}" 
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        
                        <Button Content="View Full Analytics" 
                                Command="{Binding OpenAnalyticsCommand}"
                                Margin="0,10,0,0"
                                Padding="15,10"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Show Overlay" 
                    Command="{Binding ShowOverlayCommand}"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White" />
            <Button Content="Hide to Tray" 
                    Command="{Binding HideToTrayCommand}"
                    Padding="20,10"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}" />
        </StackPanel>
    </Grid>
</Window>
