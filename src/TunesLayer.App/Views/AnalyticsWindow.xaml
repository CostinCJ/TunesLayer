<Window x:Class="TunesLayer.App.Views.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TunesLayer - Listening Analytics"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Listening Analytics" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="Track your music habits" 
                       FontSize="14" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,5,0,0" />
        </StackPanel>
        
        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Today's Listening Time -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Today" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="TodayTimeText" Text="0h 0m" 
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="listening time" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
            
            <!-- Tracks Played -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="15" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Tracks" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="TracksPlayedText" Text="0" 
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}" />
                    <TextBlock Text="played today" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
            
            <!-- Sessions -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="15" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Sessions" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="SessionsText" Text="0" 
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}" />
                    <TextBlock Text="listening sessions" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
            
            <!-- Weekly Average -->
            <Border Grid.Column="3" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="15" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Weekly Avg" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="WeeklyAvgText" Text="0h" 
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}" />
                    <TextBlock Text="per day" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Main Content - Weekly Chart and Recent Tracks -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>
            
            <!-- Weekly Chart -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="20" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Last 7 Days" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0,0,0,15" />
                    
                    <!-- Simple Bar Chart -->
                    <Grid Grid.Row="1" x:Name="ChartGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <!-- Day bars will be dynamically generated -->
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Recent Tracks -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Recent Tracks" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0,0,0,10" />
                    
                    <ListView Grid.Row="1" 
                              x:Name="RecentTracksList"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TrackTitle}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="13" />
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding PlayedAtFormatted}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="10" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{Binding Artist}" 
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="11" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Export Data" 
                    Click="ExportButton_Click"
                    Padding="15,8"
                    Margin="0,0,10,0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}" />
            <Button Content="Close" 
                    Click="CloseButton_Click"
                    Padding="15,8"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
