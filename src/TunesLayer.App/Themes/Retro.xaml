<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Retro Theme - Pixel art inspired nostalgic vibes -->
    
    <!-- Primary Colors - Warm Orange -->
    <Color x:Key="PrimaryColor">#F97316</Color>
    <Color x:Key="PrimaryHoverColor">#FB923C</Color>
    <Color x:Key="PrimaryPressedColor">#EA580C</Color>
    
    <!-- Background Colors - Warm browns and creams -->
    <Color x:Key="BackgroundColor">#1C1917</Color>
    <Color x:Key="CardBackgroundColor">#292524</Color>
    <Color x:Key="OverlayBackgroundColor">#1C1917</Color>
    <Color x:Key="OverlayInfoBackgroundColor">#0C0A09</Color>
    
    <!-- Text Colors -->
    <Color x:Key="ForegroundColor">#FEF3C7</Color>
    <Color x:Key="SecondaryTextColor">#D6D3D1</Color>
    
    <!-- Border Colors -->
    <Color x:Key="BorderColor">#44403C</Color>
    <Color x:Key="OverlayBorderColor">#F9731640</Color>
    
    <!-- Additional Colors -->
    <Color x:Key="ProgressBackgroundColor">#44403C</Color>
    <Color x:Key="AlbumArtPlaceholderColor">#292524</Color>
    <Color x:Key="SourceBadgeBackgroundColor">#F97316</Color>
    <Color x:Key="SourceBadgeForegroundColor">#1C1917</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="{StaticResource OverlayBackgroundColor}" />
    <SolidColorBrush x:Key="OverlayInfoBackgroundBrush" Color="{StaticResource OverlayInfoBackgroundColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="OverlayBorderBrush" Color="{StaticResource OverlayBorderColor}" />
    <SolidColorBrush x:Key="ProgressBackgroundBrush" Color="{StaticResource ProgressBackgroundColor}" />
    <SolidColorBrush x:Key="AlbumArtPlaceholderBrush" Color="{StaticResource AlbumArtPlaceholderColor}" />
    <SolidColorBrush x:Key="SourceBadgeBackgroundBrush" Color="{StaticResource SourceBadgeBackgroundColor}" />
    <SolidColorBrush x:Key="SourceBadgeForegroundBrush" Color="{StaticResource SourceBadgeForegroundColor}" />

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- Button Styles - Retro pixel-like with hard edges -->
    <Style x:Key="OverlayButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#FEF3C7" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="#F97316" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F97316" />
                            <Setter Property="Foreground" Value="#1C1917" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EA580C" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabItem Style - Retro -->
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border" Padding="12,8" Margin="2,0" Background="Transparent"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
